NEXT_PUBLIC_API_BASE_URL=
# IIS Express (VS) : https://localhost:44302
# Kestrel : http://127.0.0.1:5080 (préférer 127.0.0.1 en HTTP pour éviter ECONNREFUSED IPv6)
API_PROXY_TARGET=https://localhost:44302

# Clé du partenaire technique WEB (identique à Web:PartnerApiKey du backend).
NEXT_PUBLIC_WEB_PARTNER_APIKEY=dev-web-partner-apikey-CHANGE_ME
